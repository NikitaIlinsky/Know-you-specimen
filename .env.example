# Configuration settings for Know Your Specimen application

# Directories
IMAGE_INPUT_DIR=.\input_images
OUTPUT_DIR=.\output

# Debug settings
DEBUG_MODE=False

# Allowed file extensions for images
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.tiff

Talc detection parameters
SENSITIVITY=50
BRIGHT_EXCLUDE=100
DENSITY_WINDOW=17
MIN_AREA_RATIO=0.0003
MAX_DIMENSION=4000

# ML model path
ML_MODEL_PATH=src/know_your_specimen/segmentation/ore_classifier_model.pkl
